NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Production domain, used for canonical URLs, sitemap, robots.txt and Open Graph metadata.
# Update this to your real production domain when deploying (e.g. https://bookyourvibe.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Sign-In: same OAuth client ID as Backend/.env's GOOGLE_CLIENT_ID.
# Get this from https://console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID -> Web application.
# Add http://localhost:3000 to "Authorized JavaScript origins" for local dev.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=907098283956-st4kjp4fcu6jidfa7ok9bnacvf4st6j7.apps.googleusercontent.com

# Pexels API key (server-side only, never exposed to the browser).
# Used by app/api/pexels/route.ts to fetch sport-category and time-of-day photos.
PEXELS_API_KEY=rBvJ37AnAQGTZhm8x1TMKf7jxpF2Vs9JKNKmv4t3LxO1qQgxSl5UHqGu